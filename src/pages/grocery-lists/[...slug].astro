---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const docs = await getCollection('cooking', ({ id }) =>
    id.startsWith('grocery-lists/') && !id.endsWith('index.md')
  );
  return docs.map((doc) => ({
    params: { slug: doc.id.replace('grocery-lists/', '').replace('.md', '') },
    props: { doc },
  }));
}

const { doc } = Astro.props;
const { Content } = await render(doc);

const title = (doc.data.title || doc.id).replace(' | Wood Home Cooking', '').replace('grocery-lists/', '').replace('.md', '');
---

<BaseLayout title={`${title} | Wood Home Cooking`} section="grocery-lists">
  <a href="/grocery-lists/" class="back-link">← Grocery Lists</a>
  <div class="page-header">
    <div class="page-label">Grocery List</div>
    <h1>{title}</h1>
  </div>
  <button class="reset-btn">Reset all checkboxes</button>
  <article>
    <Content />
  </article>

  <!-- Checkbox persistence for grocery lists -->
  <script is:inline src="/scripts/checkbox-persist.js"></script>
</BaseLayout>