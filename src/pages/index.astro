---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allDocs = await getCollection('cooking', ({ data }) => !data.draft && data.status === 'active');

// Group by subfolder from id (e.g. "recipes/chicken-thighs" -> "recipes")
const docsByFolder: Record<string, typeof allDocs> = {};
for (const doc of allDocs) {
  const parts = doc.id.split('/');
  const folder = parts.length > 1 ? parts[0] : 'other';
  if (!docsByFolder[folder]) docsByFolder[folder] = [];
  docsByFolder[folder].push(doc);
}

// Parse recipe metadata from body for cards
function parseRecipeMeta(body: string) {
  const goutMatch = body.match(/Gout-Friendly\s*(★+☆*)/);
  const liverMatch = body.match(/Fatty\s+Liver-Friendly\s*(★+☆*)/);
  const servesMatch = body.match(/Serves:\s*(\d+[-–]?\d*)/);
  const calMatch = body.match(/~?(\d+[-–]?\d*)\s*Calories/);
  const cookMatch = body.match(/Cook:\s*(.+?)(?:\s+Gout|$)/);

  let cookMethod = cookMatch?.[1]?.trim() || '';

  return {
    goutStars: goutMatch?.[1] || '',
    liverStars: liverMatch?.[1] || '',
    serves: servesMatch?.[1] || '',
    calories: calMatch?.[1] || '',
    cookMethod,
  };
}

function getRecipeLabel(cookMethod: string, title: string): string {
  const parts: string[] = [];
  if (cookMethod) {
    if (cookMethod.includes('Crispi')) parts.push('Ninja Crispi');
    else if (cookMethod.toLowerCase().includes('stovetop')) parts.push('Stovetop');
    else parts.push(cookMethod);
  }
  const t = title.toLowerCase();
  if (['chicken', 'beef', 'shrimp', 'egg'].some(w => t.includes(w))) parts.push('Protein');
  else if (['veggie', 'veggies'].some(w => t.includes(w))) parts.push('Veggie');
  else if (['oats', 'breakfast'].some(w => t.includes(w))) parts.push('Breakfast');
  return parts.join(' · ') || 'Recipe';
}

const recipes = (docsByFolder['recipes'] || [])
  .filter(d => d.data.tags?.includes('recipe'))
  .sort((a, b) => (a.data.title || a.id).localeCompare(b.data.title || b.id));

const mealPlans = (docsByFolder['meal-plans'] || [])
  .filter(d => d.data.tags?.includes('meal-plan'))
  .sort((a, b) => (b.data.title || b.id).localeCompare(a.data.title || a.id));

const groceryLists = (docsByFolder['grocery-lists'] || [])
  .filter(d => d.data.tags?.includes('grocery'))
  .sort((a, b) => (a.data.title || a.id).localeCompare(b.data.title || b.id));
---

<BaseLayout title="Wood Home Cooking" description="Kaleb & Minny's weekly meal prep system">
  <div class="hero">
    <h1 class="hero-title">Wood Home<br><em>Cooking</em></h1>
    <p class="hero-sub">Kaleb &amp; Minny's weekly meal prep system. Built around the Ninja Crispi Pro, Monday batch cook, and eating well with Gout and Fatty Liver in mind.</p>
    <div class="badge-row">
      <span class="badge clay">1,800–2,000 cal / day</span>
      <span class="badge">Monday batch cook</span>
      <span class="badge">Gout &amp; Fatty Liver friendly</span>
    </div>
  </div>

  {recipes.length > 0 && (
    <>
      <h2>Recipe Library</h2>
      <div class="card-grid">
        {recipes.map((doc) => {
          const slug = doc.id.replace('recipes/', '').replace('.md', '');
          const meta = parseRecipeMeta(doc.body ?? '');
          const title = (doc.data.title || slug).replace(' | Wood Home Cooking', '');
          const label = getRecipeLabel(meta.cookMethod, title);
          const metaParts = [meta.serves ? `${meta.serves} servings` : '', meta.calories ? `~${meta.calories} cal` : ''].filter(Boolean);

          return (
            <a href={`/recipes/${slug}/`} class="card">
              <div class="card-label">{label}</div>
              <div class="card-title">{title}</div>
              {metaParts.length > 0 && <div class="card-meta">{metaParts.map(p => <span>{p}</span>)}</div>}

              {(meta.goutStars || meta.liverStars) && (
                <div class="card-ratings">
                  {meta.goutStars && <div class="mini-rating">Gout <span class="stars">{meta.goutStars}</span></div>}
                  {meta.liverStars && <div class="mini-rating">Liver <span class="stars">{meta.liverStars}</span></div>}
                </div>
              )}
            </a>
          );
        })}
      </div>
    </>
  )}

  {mealPlans.length > 0 && (
    <>
      <h2>Meal Plans</h2>
      <div class="card-grid">
        {mealPlans.map((doc) => {
          const slug = doc.id.replace('meal-plans/', '').replace('.md', '');
          const title = (doc.data.title || slug).replace(' | Wood Home Cooking', '');
          const label = /^\d{4}-\d{2}$/.test(slug) ? 'Monthly Plan' : 'Weekly Plan';

          return (
            <a href={`/meal-plans/${slug}/`} class="card">
              <div class="card-label">{label}</div>
              <div class="card-title">{title}</div>
            </a>
          );
        })}
      </div>
    </>
  )}

  {groceryLists.length > 0 && (
    <>
      <h2>Grocery Lists</h2>
      <div class="card-grid">
        {groceryLists.map((doc) => {
          const slug = doc.id.replace('grocery-lists/', '').replace('.md', '');
          const title = (doc.data.title || slug).replace(' | Wood Home Cooking', '');
          const body = doc.body ?? '';
          const stores: string[] = [];
          if (body.includes('Costco') || body.includes("Sam's")) stores.push("Costco/Sam's");
          if (body.includes('HEB') || body.includes('H-E-B')) stores.push('HEB');
          const label = stores.join(' · ') || 'Grocery List';

          return (
            <a href={`/grocery-lists/${slug}/`} class="card">
              <div class="card-label">{label}</div>
              <div class="card-title">{title}</div>
            </a>
          );
        })}
      </div>
    </>
  )}

  <!-- Pagefind search UI -->
  <div id="search" style="max-width:480px;margin:1rem auto 2rem;"></div>
  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  <script is:inline>
    window.addEventListener('DOMContentLoaded', () => {
      if (typeof PagefindUI !== 'undefined') {
        new PagefindUI({
          element: '#search',
          showSubResults: true,
          showImages: false,
        });
      }
    });
  </script>
</BaseLayout>