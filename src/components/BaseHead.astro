---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  domain?: string;
}

const { title, description = '', domain = 'kitchen' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="theme-color" content="#11151C" />
<meta name="generator" content={Astro.generator} />

<!-- Canonical & SEO -->
<link rel="canonical" href={canonicalURL} />
<title>{title}</title>
{description && <meta name="description" content={description} />}

<!-- Fonts: Playfair Display + Inter + JetBrains Mono -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;1,600&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
  rel="stylesheet"
/>

<!-- M3 Theme from CDN (fallback, primary load is via CSS import) -->
<link rel="stylesheet" href="https://theme.kaleb.one/dist/components.css" />